# Copier ce fichier vers .env et renseigner les valeurs.

# Ne jamais committer .env.



# --- APIs gratuites (prototypage, sans OpenAI) ---

# Clé Google AI Studio / Gemini : https://aistudio.google.com/apikey

GEMINI_API_KEY=



# Modèle vision (texte + image). Ex. gemini-2.5-flash (recommandé), gemini-2.5-flash-lite

GEMINI_VISION_MODEL=gemini-2.5-flash



# Génération d’images : Replicate, côté frontend (voir frontend/.env.example — REPLICATE_API_TOKEN).

# Origines autorisées pour CORS (séparées par des virgules)

# Exemple dev : http://localhost:3000

# Exemple prod : https://votre-app.vercel.app

# Mettre true si le navigateur appelle l’API depuis *.vercel.app (previews / NEXT_PUBLIC_API_URL).

CORS_ALLOW_VERCEL=false



# Inclure chaque origine du navigateur (localhost vs 127.0.0.1, ports 3000/3001 si Next change de port)

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001



# Port d'écoute (Render/Fly utilisent souvent la variable PORT)

PORT=8000



# Optionnel : surcharge JSON des tarifs (fusionné avec les valeurs par défaut).

# Exemple minimal : {"salon":{"base_eur_per_m2":120}}

ROOM_RATES_JSON=

