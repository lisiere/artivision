{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ArtiVision : dev local (API + web)",
      "type": "npm",
      "script": "dev",
      "path": ".",
      "problemMatcher": {
        "owner": "artivision-dev",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Ready in|✓ Ready|Local:|Uvicorn running)"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "artivision"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
