# Laisser VIDE en local : le navigateur appelle /api/... sur Next, qui proxifie vers l’API (voir next.config.mjs).
# Renseignez une URL seulement si le front doit parler directement à l’API (mobile, autre domaine).
NEXT_PUBLIC_API_URL=

# Cible interne du proxy Next → FastAPI (défaut http://127.0.0.1:8000).
# Sur Vercel : URL HTTPS de l’API déployée (ex. https://xxx.onrender.com), sans slash final — obligatoire pour /app.
# Définir pour Production et Preview dans le dashboard Vercel ; relancer un deploy après changement.
# INTERNAL_API_URL=https://votre-api.example.com

# Replicate (génération d’images /api/generate) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Supabase (SaaS B2B — Sprint 1+) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Routes serveur uniquement (ne jamais exposer au navigateur)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe / Resend — sprints suivants (voir docs/PIVOT_B2B.md)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
