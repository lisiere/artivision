# Laisser VIDE en local : le navigateur appelle /api/... sur Next, qui proxy vers FastAPI (Route Handlers).
# Renseignez une URL seulement si le front doit parler directement à l’API (mobile, autre domaine).
NEXT_PUBLIC_API_URL=

# Cible du proxy serveur Next → FastAPI (voir `lib/internalBackend.ts`). Défaut local : http://127.0.0.1:8000.
# Sur Vercel Services : laisser vide pour utiliser `https://${VERCEL_URL}/_/backend`.
# INTERNAL_API_URL=https://votre-api.example.com

# Vercel uniquement : injecté automatiquement si « Protection Bypass for Automation » est activé sur le projet.
# Permet au serveur Next d’appeler `/_/backend` malgré la protection des previews.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Replicate (génération d’images /api/generate) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Supabase (SaaS B2B — Sprint 1+) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Routes serveur uniquement (ne jamais exposer au navigateur)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe / Resend — sprints suivants (voir docs/PIVOT_B2B.md)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
